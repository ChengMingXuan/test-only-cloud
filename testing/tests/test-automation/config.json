{
  "test_environment": {
    "api_base_url": "http://localhost:8000/api",
    "frontend_url": "http://localhost:8000",
    "admin_ui_url": "http://localhost:8000",
    "timeout_seconds": 30
  },
  
  "database": {
    "account": {
      "host": "localhost",
