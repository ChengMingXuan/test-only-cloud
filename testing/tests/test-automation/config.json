    },
    "charging": {
      "host": "localhost",
      "port": 5432,
      "database": "jgsy_charging",
      "user": "postgres",
      "password": "postgres"
    },
    "device": {
      "host": "localhost",
      "port": 5432,
      "database": "jgsy_device",
      "user": "postgres",
      "password": "postgres"
    },
    "workorder": {
      "host": "localhost",
      "port": 5432,
      "database": "jgsy_workorder",
      "user": "postgres",
      "password": "postgres"
    }
  },
  
  "test_accounts": {
    "superadmin": {
      "username": "admin",
      "password": "Admin@123",
      "email": "admin@example.com",
      "role": "SUPER_ADMIN",
      "description": "超级管理员"
    },
    "tenant_admin": {
      "username": "tenant_admin",
      "password": "TenantAdmin@123",
      "email": "tenant_admin@example.com",
      "role": "TENANT_ADMIN",
      "description": "租户管理员"
    },
    "operator": {
      "username": "operator",
      "password": "Operator@123",
      "email": "operator@example.com",
      "role": "OPERATOR",
      "description": "运营员"
    }
  },
  
  "test_data_defaults": {
    "test_tenant_name_prefix": "TEST_TENANT_",
    "test_user_name_prefix": "testuser_",
    "test_email_domain": "test.example.com",
    "test_phone_prefix": "138",
    "test_address": "北京市朝阳区建国路"
  },
  
  "performance_sla": {
    "api_average_response_ms": 200,
    "api_p99_response_ms": 1000,
    "api_error_rate_percent": 0.1,
    "concurrent_users": 500,
    "database_qps": 5000,
    "message_queue_throughput": 10000,
    "signalr_concurrent_connections": 1000,
    "dashboard_load_time_seconds": 2
  },
  
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "tests/test-results/test-execution.log"
  },
  
  "report_output": {
    "format": "html",
    "directory": "tests/test-results/",
    "coverage_report": "tests/test-results/coverage.html",
    "performance_report": "tests/test-results/performance.json"
  }
}
